# Server Configuration
PORT=5000

# MongoDB Database Connection String
# Replace <username>, <password>, and <cluster-url> with your actual MongoDB Atlas credentials.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/code_reviewer_db

# JSON Web Token Secret
# Use a strong, random string in production (e.g., generated via 'openssl rand -hex 32')
JWT_SECRET=your_placeholder_jwt_secret_key_here

# Google Gemini API Key
# Obtain this from Google AI Studio (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_placeholder_gemini_api_key_here

# Frontend URL (for CORS - set this to your Vercel deployment URL in production)
# Example: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173
